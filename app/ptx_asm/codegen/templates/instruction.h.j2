class Instruction {
public:
    Instruction() = default;
    virtual void Execute(std::shared_ptr<WarpContext>& wc) = 0;
    virtual void Dump() = 0;
    virtual std::string_view Name() const = 0;
    virtual bool HasExplicitPredicate() const { return false; }
};

