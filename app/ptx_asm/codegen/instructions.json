{
    "operands": {
        "addressOperand": {
            "regexp": "[\\[\\]A-Za-z0-9_\\+\\-%]+"
        },
        "registerOperand": {
            "regexp": "%[a-z]+[0-9]*,?"
        },
        "sprRegisterOperand": {
            "regexp": "%[a-z]+\\.?[xyz]?"
        },
        "symbolOperand": {
            "regexp": "[A-z0-9_]+"
        },
        "immediateOperand": {
            "regexp": "0?x?[\\-A-Fa-f0-9]+"
        }
    },
    "types": {
        "dataType": {
            "regexp": "[fsub]8|[fsub]16|[fsub]32|[fsub]64|pred",
            "values": [
                "f16",
                "f32",
                "f64",
                "s8",
                "s16",
                "s32",
                "s64",
                "u8",
                "u16",
                "u32",
                "u64",
                "pred"
            ]
        },
        "registerType": {
            "regexp": "p|r|rd|spr",
            "values": [
                "p",
                "r",
                "rd",
                "spr"
            ]
        },
        "sprType": {
            "values": [
                "tid",
                "ntid",
                "laneid",
                "warpid",
                "nwarpid",
                "ctaid",
                "nctaid",
                "smid",
                "nsmid",
                "gridid",
                "is_explicit_cluster",
                "clusterid",
                "nclusterid",
                "cluster_ctaid"
            ]
        }
    },
    "instructions": {
        "param": {
            "regexp_template": "\\.param\\s\\.($data)\\s($symbol),?",
            "params": {
                "data": {
                    "arg_type": "local",
                    "dtype": "dataType"
                },
                "symbol": {
                    "arg_type": "symbolOperand"
                }
            },
            "exec_type": "warp"
        },
        "reg": {
            "regexp_template": "\\.reg\\s\\.($data)\\s%($reg)<($count)>;",
            "params": {
                "data": {
                    "arg_type": "local",
                    "dtype": "dataType"
                },
                "reg": {
                    "arg_type": "local",
                    "dtype": "registerType"
                },
                "count": {
                    "regexp": "[0-9]+",
                    "arg_type": "local",
                    "dtype": "uint32_t"
                }
            },
            "exec_type": "thread"
        },
        "pragma": {
            "regexp_template": "\\.pragma\\s.($val).;",
            "params": {
                "val": {
                    "values": [
                        "nounroll"
                    ],
                    "arg_type": "qualifier"
                }
            },
            "exec_type": "warp"
        },
        "abs": {},
